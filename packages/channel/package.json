{
  "name": "@snowluma/channel",
  "version": "1.9.2",
  "private": true,
  "type": "module",
  "description": "SnowLuma transport abstract layer. Defines the `Channel` abstract base + `ChannelCtx` capability POJO + `ChannelAdapter` port that `Hub` (in @snowluma/core) consumes. Concrete transports live in `@snowluma/channel-hook` (in-process NTQQ hook) and `@snowluma/channel-socket` (future pure-socket).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./channel": {
      "types": "./src/channel.ts",
      "default": "./src/channel.ts"
    },
    "./channel-interface": {
      "types": "./src/channel-interface.ts",
      "default": "./src/channel-interface.ts"
    },
    "./channel-ctx": {
      "types": "./src/channel-ctx.ts",
      "default": "./src/channel-ctx.ts"
    },
    "./adapter": {
      "types": "./src/adapter.ts",
      "default": "./src/adapter.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@snowluma/common": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.4"
  }
}
