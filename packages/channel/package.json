{
  "name": "@snowluma/channel",
  "version": "1.9.2",
  "private": true,
  "type": "module",
  "description": "SnowLuma transport layer (v3 rename of @snowluma/bridge). Defines the abstract `Channel` + `ChannelCtx` capability POJO + `ChannelAdapter` port that the Hub in @snowluma/core consumes, plus the in-process NTQQ hook runtime (HookManager / HookSession / pipe-watcher / injector / HookChannel / HookAdapter). The future `channel-socket` package will provide an alternative ChannelAdapter implementation.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./channel": {
      "types": "./src/channel.ts",
      "default": "./src/channel.ts"
    },
    "./channel-interface": {
      "types": "./src/channel-interface.ts",
      "default": "./src/channel-interface.ts"
    },
    "./channel-ctx": {
      "types": "./src/channel-ctx.ts",
      "default": "./src/channel-ctx.ts"
    },
    "./adapter": {
      "types": "./src/adapter.ts",
      "default": "./src/adapter.ts"
    },
    "./manager": {
      "types": "./src/manager.ts",
      "default": "./src/manager.ts"
    },
    "./hook-channel": {
      "types": "./src/hook-channel.ts",
      "default": "./src/hook-channel.ts"
    },
    "./hook-adapter": {
      "types": "./src/hook-adapter.ts",
      "default": "./src/hook-adapter.ts"
    },
    "./socket-channel": {
      "types": "./src/socket-channel.ts",
      "default": "./src/socket-channel.ts"
    },
    "./socket-adapter": {
      "types": "./src/socket-adapter.ts",
      "default": "./src/socket-adapter.ts"
    },
    "./hook-manager": {
      "types": "./src/hook-manager.ts",
      "default": "./src/hook-manager.ts"
    },
    "./hook-session": {
      "types": "./src/hook-session.ts",
      "default": "./src/hook-session.ts"
    },
    "./hook-packet-client": {
      "types": "./src/hook-packet-client.ts",
      "default": "./src/hook-packet-client.ts"
    },
    "./injector": {
      "types": "./src/injector.ts",
      "default": "./src/injector.ts"
    },
    "./pipe-watcher": {
      "types": "./src/pipe-watcher.ts",
      "default": "./src/pipe-watcher.ts"
    },
    "./qq-hook-client": {
      "types": "./src/qq-hook-client.ts",
      "default": "./src/qq-hook-client.ts"
    },
    "./qq-port-probe": {
      "types": "./src/qq-port-probe.ts",
      "default": "./src/qq-port-probe.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@snowluma/common": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.4"
  }
}
