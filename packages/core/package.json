{
  "name": "@snowluma/core",
  "version": "1.9.2",
  "description": "SnowLuma core - NTQQ packet sniffer with Node.js native addon",
  "private": true,
  "type": "module",
  "main": "../../dist/index.mjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "../../dist/index.mjs"
    },
    "./core": {
      "types": "./src/core.ts",
      "default": "./src/core.ts"
    },
    "./core-context": {
      "types": "./src/core-context.ts",
      "default": "./src/core-context.ts"
    },
    "./core-ctx": {
      "types": "./src/core-ctx.ts",
      "default": "./src/core-ctx.ts"
    },
    "./hub": {
      "types": "./src/hub.ts",
      "default": "./src/hub.ts"
    },
    "./apis": {
      "types": "./src/apis/index.ts",
      "default": "./src/apis/index.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:all": "cross-env BUILD_WEBUI=true vite build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@snowluma/channel": "workspace:*",
    "@snowluma/channel-hook": "workspace:*",
    "@snowluma/channel-socket": "workspace:*",
    "@snowluma/common": "workspace:*",
    "@snowluma/onebot": "workspace:*",
    "@snowluma/protocol": "workspace:*",
    "@snowluma/proto-defs": "workspace:*",
    "@snowluma/proton": "workspace:*",
    "@snowluma/websocket": "workspace:*"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.14",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^24.12.2",
    "cross-env": "^10.1.0",
    "hono": "^4.12.18",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-cp": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
